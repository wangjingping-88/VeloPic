<Application
    x:Class="VeloPic.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0D141E"/>
                    <SolidColorBrush x:Key="ChromeBrush" Color="#111925"/>
                    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#151F2C"/>
                    <SolidColorBrush x:Key="PanelAltBrush" Color="#101925"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1D2938"/>
                    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#1B2431"/>
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EEF3FA"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A8B3C3"/>
                    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#748095"/>
                    <SolidColorBrush x:Key="BorderSubtleBrush" Color="#273447"/>
                    <SolidColorBrush x:Key="BorderStrongBrush" Color="#4A5B73"/>
                    <SolidColorBrush x:Key="InteractiveBorderBrush" Color="#53657E"/>
                    <SolidColorBrush x:Key="InteractiveBorderPointerOverBrush" Color="#6A7D98"/>
                    <SolidColorBrush x:Key="InteractiveBorderPressedBrush" Color="#7F93AE"/>
                    <SolidColorBrush x:Key="ActionButtonBorderBrush" Color="#647892"/>
                    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="#368BFF"/>
                    <SolidColorBrush x:Key="AccentHoverBrush" Color="#3C8DFF"/>
                    <SolidColorBrush x:Key="AccentSoftBrush" Color="#193F7D"/>
                    <SolidColorBrush x:Key="SuccessBrush" Color="#48D06D"/>
                    <SolidColorBrush x:Key="WarningBrush" Color="#FFD45C"/>
                    <SolidColorBrush x:Key="ButtonBackground" Color="#263141"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#303C4F"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#1F2937"/>
                    <SolidColorBrush x:Key="ButtonForeground" Color="#EEF3FA"/>
                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#53657E"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#6A7D98"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#7F93AE"/>
                    <SolidColorBrush x:Key="ToggleButtonBorderBrush" Color="#53657E"/>
                    <SolidColorBrush x:Key="ToggleButtonBorderBrushPointerOver" Color="#6A7D98"/>
                    <SolidColorBrush x:Key="ToggleButtonBorderBrushPressed" Color="#7F93AE"/>
                    <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="#368BFF"/>
                    <SolidColorBrush x:Key="TextControlBackground" Color="#1B2431"/>
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#202B3A"/>
                    <SolidColorBrush x:Key="TextControlForeground" Color="#EEF3FA"/>
                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#7E8A9D"/>
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#354255"/>
                    <SolidColorBrush x:Key="ComboBoxBackground" Color="#1B2431"/>
                    <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#202B3A"/>
                    <SolidColorBrush x:Key="ComboBoxForeground" Color="#EEF3FA"/>
                    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#354255"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#EDF2F8"/>
                    <SolidColorBrush x:Key="ChromeBrush" Color="#F6F9FD"/>
                    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="PanelAltBrush" Color="#E9EFF6"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#E4ECF5"/>
                    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#182233"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#536176"/>
                    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#7A8798"/>
                    <SolidColorBrush x:Key="BorderSubtleBrush" Color="#D4DEEA"/>
                    <SolidColorBrush x:Key="BorderStrongBrush" Color="#A7B7CA"/>
                    <SolidColorBrush x:Key="InteractiveBorderBrush" Color="#9CADC1"/>
                    <SolidColorBrush x:Key="InteractiveBorderPointerOverBrush" Color="#7F95AD"/>
                    <SolidColorBrush x:Key="InteractiveBorderPressedBrush" Color="#6B839D"/>
                    <SolidColorBrush x:Key="ActionButtonBorderBrush" Color="#8195AC"/>
                    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="#246FE5"/>
                    <SolidColorBrush x:Key="AccentHoverBrush" Color="#155FCC"/>
                    <SolidColorBrush x:Key="AccentSoftBrush" Color="#DCEAFF"/>
                    <SolidColorBrush x:Key="SuccessBrush" Color="#22A654"/>
                    <SolidColorBrush x:Key="WarningBrush" Color="#D79518"/>
                    <SolidColorBrush x:Key="ButtonBackground" Color="#E6ECF3"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#DDE6F0"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CED9E6"/>
                    <SolidColorBrush x:Key="ButtonForeground" Color="#182233"/>
                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#9CADC1"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#7F95AD"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#6B839D"/>
                    <SolidColorBrush x:Key="ToggleButtonBorderBrush" Color="#9CADC1"/>
                    <SolidColorBrush x:Key="ToggleButtonBorderBrushPointerOver" Color="#7F95AD"/>
                    <SolidColorBrush x:Key="ToggleButtonBorderBrushPressed" Color="#6B839D"/>
                    <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="#246FE5"/>
                    <SolidColorBrush x:Key="TextControlBackground" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#F7FAFD"/>
                    <SolidColorBrush x:Key="TextControlForeground" Color="#182233"/>
                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#7A8798"/>
                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="#C6D2E0"/>
                    <SolidColorBrush x:Key="ComboBoxBackground" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#F7FAFD"/>
                    <SolidColorBrush x:Key="ComboBoxForeground" Color="#182233"/>
                    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#C6D2E0"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <Style x:Key="PanelBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource PanelBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource BorderSubtleBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
            </Style>

            <Style x:Key="InsetPanelStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource PanelAltBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource BorderSubtleBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="6"/>
            </Style>

            <Style x:Key="CompactButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="32"/>
                <Setter Property="Padding" Value="11,5"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Microsoft YaHei UI, Segoe UI"/>
                <Setter Property="BorderBrush" Value="{ThemeResource InteractiveBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="VeloToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
                <Setter Property="MinHeight" Value="36"/>
                <Setter Property="Padding" Value="12,5"/>
                <Setter Property="CornerRadius" Value="5"/>
                <Setter Property="BorderBrush" Value="{ThemeResource BorderStrongBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="SortDirectionButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
                <Setter Property="Padding" Value="6,0"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="ThemeModeButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
                <Setter Property="Padding" Value="5,0"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="SelectionToggleButtonStyle" TargetType="ToggleButton">
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
                <Setter Property="Padding" Value="5,0"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Microsoft YaHei UI, Segoe UI"/>
                <Setter Property="BorderBrush" Value="{ThemeResource InteractiveBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="QuietActionButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="26"/>
                <Setter Property="Padding" Value="5,2"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Microsoft YaHei UI, Segoe UI"/>
            </Style>

            <Style x:Key="IconTileButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
                <Setter Property="MinHeight" Value="48"/>
                <Setter Property="Padding" Value="6"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
            </Style>

            <Style x:Key="QuickActionButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
                <Setter Property="MinHeight" Value="46"/>
                <Setter Property="Padding" Value="3"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="BorderBrush" Value="{ThemeResource ActionButtonBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
            </Style>

            <Style x:Key="DetailBarButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
                <Setter Property="MinHeight" Value="30"/>
                <Setter Property="Padding" Value="4,3"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="CornerRadius" Value="5"/>
                <Setter Property="BorderBrush" Value="{ThemeResource ActionButtonBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="WallpaperFitButtonStyle" TargetType="ToggleButton">
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="MinHeight" Value="48"/>
                <Setter Property="Padding" Value="3"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Microsoft YaHei UI, Segoe UI"/>
                <Setter Property="BorderBrush" Value="{ThemeResource ActionButtonBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Microsoft YaHei UI, Segoe UI"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Microsoft YaHei UI, Segoe UI"/>
                <Setter Property="MinHeight" Value="36"/>
                <Setter Property="Padding" Value="10,7,10,4"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontFamily" Value="Segoe UI Variable Text, Microsoft YaHei UI, Segoe UI"/>
            </Style>

            <Style x:Key="SecondaryTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}"/>
                <Setter Property="FontSize" Value="11"/>
            </Style>

            <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextTertiaryBrush}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
