<Window
    x:Class="VeloPic.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="VeloPic 疾图">

    <Grid x:Name="RootGrid"
          SizeChanged="RootGrid_OnSizeChanged"
          KeyboardAcceleratorPlacementMode="Hidden"
          Background="{ThemeResource AppBackgroundBrush}">
        <Grid.Resources>
            <CollectionViewSource x:Name="GroupedMediaSource"
                                  IsSourceGrouped="True"
                                  ItemsPath="VisibleItems"/>
        </Grid.Resources>
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="ViewerEscapeAccelerator_OnInvoked"/>
            <KeyboardAccelerator Key="Left" Invoked="ViewerPreviousAccelerator_OnInvoked"/>
            <KeyboardAccelerator Key="Right" Invoked="ViewerNextAccelerator_OnInvoked"/>
        </Grid.KeyboardAccelerators>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="38"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftPaneColumn" Width="232"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="RightPaneColumn" Width="340"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3"
                Background="{ThemeResource ChromeBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,11">
            <Grid ColumnSpacing="10" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="HeaderBrandColumn" Width="184"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <Image Width="30"
                           Height="30"
                           Source="Assets/AppIcon.png"
                           Stretch="Uniform"
                           AutomationProperties.Name="VeloPic 疾图应用图标"/>
                    <TextBlock Text="VeloPic 疾图" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid x:Name="SortModeGrid"
                      Grid.Column="3"
                      Width="326"
                      Height="36"
                      ColumnSpacing="4"
                      HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="排序"
                               Margin="0,0,4,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <Button x:Name="ModifiedTimeSortButton"
                            Grid.Column="1"
                            Height="36"
                            Tag="ModifiedTime"
                            Content="修改时间"
                            Style="{StaticResource ThemeModeButtonStyle}"
                            Click="SortFieldButton_OnClick"/>
                    <Button x:Name="FileNameSortButton"
                            Grid.Column="2"
                            Height="36"
                            Tag="FileName"
                            Content="文件名"
                            Style="{StaticResource ThemeModeButtonStyle}"
                            Click="SortFieldButton_OnClick"/>
                    <Button x:Name="FileSizeSortButton"
                            Grid.Column="3"
                            Height="36"
                            Tag="FileSize"
                            Content="大小"
                            Style="{StaticResource ThemeModeButtonStyle}"
                            Click="SortFieldButton_OnClick"/>
                    <Button x:Name="SortDirectionButton"
                            Grid.Column="4"
                            Width="56"
                            Height="36"
                            Style="{StaticResource SortDirectionButtonStyle}"
                            AutomationProperties.Name="切换排序方向"
                            Click="SortDirectionButton_OnClick">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon x:Name="SortDirectionIcon"
                                      Glyph="&#xE70D;"
                                      FontSize="11"
                                      Foreground="{ThemeResource AccentPrimaryBrush}"/>
                            <TextBlock x:Name="SortDirectionLabel"
                                       Text="降序"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Button x:Name="FilterButton"
                        Grid.Column="1"
                        Width="112"
                        Height="36"
                        HorizontalAlignment="Left"
                        Style="{StaticResource VeloToolbarButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE71C;" FontSize="13"/>
                        <TextBlock x:Name="FilterButtonLabel" Text="筛选"/>
                    </StackPanel>
                    <Button.Flyout>
                        <Flyout x:Name="FilterFlyout" Placement="BottomEdgeAlignedLeft">
                            <StackPanel Width="280" Spacing="10" Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="FilterPanelTitle" Text="筛选图片" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource QuietActionButtonStyle}"
                                            Click="ResetFiltersButton_OnClick"
                                            Content="清除"/>
                                </Grid>
                                <TextBlock Text="文件名" Style="{StaticResource SectionLabelStyle}"/>
                                <TextBox x:Name="FilterNameBox"
                                         Height="36"
                                         Style="{StaticResource SingleLineTextBoxStyle}"
                                         PlaceholderText="输入文件名"
                                         TextChanged="FilterNameBox_OnTextChanged"/>
                                <StackPanel x:Name="ResolutionFilterSection" Spacing="10">
                                    <TextBlock Text="分辨率" Style="{StaticResource SectionLabelStyle}"/>
                                    <ComboBox x:Name="ResolutionFilterBox"
                                              HorizontalAlignment="Stretch"
                                              SelectedIndex="0"
                                              IsEnabled="False"
                                              SelectionChanged="FilterBox_OnSelectionChanged">
                                        <ComboBoxItem Content="全部分辨率" Tag="all"/>
                                        <ComboBoxItem Content="4K 及以上（3840 × 2160）" Tag="4k"/>
                                        <ComboBoxItem Content="2K 及以上（2560 × 1440）" Tag="2k"/>
                                        <ComboBoxItem Content="1K 及以上（1920 × 1080）" Tag="1k"/>
                                    </ComboBox>
                                    <TextBlock Text="画面方向" Style="{StaticResource SectionLabelStyle}"/>
                                    <ComboBox x:Name="OrientationFilterBox"
                                              HorizontalAlignment="Stretch"
                                              SelectedIndex="0"
                                              IsEnabled="False"
                                              SelectionChanged="FilterBox_OnSelectionChanged">
                                        <ComboBoxItem Content="全部方向" Tag="all"/>
                                        <ComboBoxItem Content="横屏（宽度大于高度）" Tag="landscape"/>
                                        <ComboBoxItem Content="竖屏（高度大于宽度）" Tag="portrait"/>
                                    </ComboBox>
                                    <TextBlock x:Name="FilterMetadataStatusText"
                                               Text="选择文件夹后读取分辨率"
                                               Style="{StaticResource SecondaryTextStyle}"/>
                                </StackPanel>
                                <TextBlock Text="文件类型" Style="{StaticResource SectionLabelStyle}"/>
                                <ComboBox x:Name="FileTypeFilterBox"
                                          HorizontalAlignment="Stretch"
                                          SelectedIndex="0"
                                          SelectionChanged="FilterBox_OnSelectionChanged">
                                    <ComboBoxItem Content="全部类型" Tag="all"/>
                                </ComboBox>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Spacing="8">
                    <Button x:Name="ChooseFolderButton" Width="112" Height="36" Style="{StaticResource VeloToolbarButtonStyle}" Click="ChooseFolderButton_OnClick">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8B7;" FontSize="14"/>
                            <TextBlock Text="导入文件夹"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="RescanButton" Width="112" Height="36" Style="{StaticResource VeloToolbarButtonStyle}" Click="RescanButton_OnClick">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                            <TextBlock Text="重新扫描"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border x:Name="HeaderPathBar"
                        Grid.Column="4"
                        Height="36"
                        MinWidth="180"
                        MaxWidth="520"
                        Margin="2,0,8,0"
                        Padding="11,0"
                        HorizontalAlignment="Stretch"
                        Style="{StaticResource InsetPanelStyle}">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE8B7;"
                                  FontSize="13"
                                  Foreground="{ThemeResource TextSecondaryBrush}"
                                  VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   x:Name="HeaderPathText"
                                   Text="尚未选择图片文件夹"
                                   Foreground="{ThemeResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTipService.ToolTip="{Binding Text, ElementName=HeaderPathText}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid x:Name="ThemeModeGrid"
                      Grid.Column="5"
                      Width="318"
                      Height="36"
                      ColumnSpacing="4"
                      HorizontalAlignment="Right">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="主题"
                               Margin="0,0,4,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <ToggleButton x:Name="SystemThemeButton"
                            Grid.Column="1"
                            Height="36"
                            Tag="System"
                            Content="跟随系统"
                            Style="{StaticResource SelectionToggleButtonStyle}"
                            Click="ThemeModeButton_OnClick"/>
                    <ToggleButton x:Name="DarkThemeButton"
                            Grid.Column="2"
                            Height="36"
                            Tag="Dark"
                            Content="深色"
                            Style="{StaticResource SelectionToggleButtonStyle}"
                            Click="ThemeModeButton_OnClick"/>
                    <ToggleButton x:Name="LightThemeButton"
                            Grid.Column="3"
                            Height="36"
                            Tag="Light"
                            Content="浅色"
                            Style="{StaticResource SelectionToggleButtonStyle}"
                            Click="ThemeModeButton_OnClick"/>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="LeftSidebar" Grid.Row="1" Grid.Column="0" Margin="8,8,6,8" Padding="14" Style="{StaticResource PanelBorderStyle}">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="导航" Style="{StaticResource SectionLabelStyle}"/>

                <StackPanel Grid.Row="1" Spacing="4">
                    <Button x:Name="FolderNavigationItem"
                            Background="{ThemeResource SelectionBackgroundBrush}"
                            Foreground="{ThemeResource SelectionForegroundBrush}"
                            Tag="folder"
                            AutomationProperties.Name="当前文件夹"
                            Style="{StaticResource NavigationItemButtonStyle}"
                            Click="NavigationItem_OnClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8B7;"
                                      FontSize="14"
                                      Foreground="{Binding Foreground, ElementName=FolderNavigationItem}"/>
                            <TextBlock Text="当前文件夹" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="FavoritesNavigationItem" Tag="favorites" AutomationProperties.Name="收藏" Style="{StaticResource NavigationItemButtonStyle}" Click="NavigationItem_OnClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE734;" FontSize="14" Foreground="{ThemeResource WarningBrush}"/>
                            <TextBlock Text="收藏"/>
                        </StackPanel>
                    </Button>
                    <StackPanel Spacing="2">
                        <Button x:Name="AlbumsNavigationItem"
                              Tag="albums"
                              AutomationProperties.Name="展开相册列表"
                              Style="{StaticResource NavigationItemButtonStyle}"
                              Click="NavigationItem_OnClick">
                            <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEB9F;" FontSize="14" Foreground="#B28CFF"/>
                                <TextBlock Text="相册"/>
                            </StackPanel>
                            <FontIcon x:Name="AlbumsChevronIcon"
                                      Grid.Column="1"
                                      Glyph="&#xE76C;"
                                      FontSize="11"
                                      Foreground="{ThemeResource TextSecondaryBrush}"
                                      VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Border x:Name="AlbumListContainer"
                                Margin="24,0,0,2"
                                Visibility="Collapsed">
                            <ScrollViewer MaxHeight="144"
                                          VerticalScrollMode="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="AlbumListPanel" Spacing="2"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                    <Button x:Name="RecentNavigationItem" Tag="recent" AutomationProperties.Name="最近" Style="{StaticResource NavigationItemButtonStyle}" Click="NavigationItem_OnClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE823;"
                                      FontSize="14"
                                      Foreground="{Binding Foreground, ElementName=RecentNavigationItem}"/>
                            <TextBlock Text="最近"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="WallpaperNavigationItem" Tag="wallpaper" AutomationProperties.Name="壁纸收藏夹" Style="{StaticResource NavigationItemButtonStyle}" Click="NavigationItem_OnClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7F4;" FontSize="14" Foreground="#80D6FF"/>
                            <TextBlock Text="壁纸收藏夹"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Row="2" Height="1" Background="{ThemeResource BorderSubtleBrush}" Margin="0,4"/>

                <StackPanel Grid.Row="3" Spacing="8">
                    <TextBlock Text="当前目录" Style="{StaticResource SectionLabelStyle}"/>
                    <TextBlock x:Name="CurrentFolderText"
                               Text="未选择目录"
                               FontSize="12"
                               TextWrapping="WrapWholeWords"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="FolderStatsText" Text="0 张图片" Style="{StaticResource SecondaryTextStyle}"/>
                </StackPanel>

                <Grid Grid.Row="4" RowSpacing="8" MinHeight="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="分类" Style="{StaticResource SectionLabelStyle}"/>
                    <Grid Grid.Row="1" ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    x:Name="AddCustomCategoryButton"
                                    Style="{StaticResource CategoryActionButtonStyle}"
                                    Click="AddCustomCategoryButton_OnClick"
                                    ToolTipService.ToolTip="新增自定义标签">
                                <StackPanel Orientation="Horizontal" Spacing="3">
                                    <FontIcon Glyph="&#xE710;" FontSize="10" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                    <TextBlock Text="新增" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1"
                                    x:Name="ManualClassificationButton"
                                    IsEnabled="False"
                                    Style="{StaticResource CategoryActionButtonStyle}"
                                    ToolTipService.ToolTip="将选中的图片标记到指定分类">
                                <StackPanel Orientation="Horizontal" Spacing="3">
                                    <FontIcon Glyph="&#xE8EC;" FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                    <TextBlock Text="标记" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2"
                                    x:Name="SmartClassificationButton"
                                    Style="{StaticResource CategoryActionButtonStyle}"
                                    Click="SmartClassificationButton_OnClick"
                                    ToolTipService.ToolTip="使用本地视觉模型自动归类当前图片">
                                <StackPanel Orientation="Horizontal" Spacing="3">
                                    <FontIcon Glyph="&#xE945;" FontSize="11" Foreground="{ThemeResource AccentPrimaryBrush}"/>
                                    <TextBlock Text="智能" Foreground="{ThemeResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Button>
                    </Grid>
                    <TextBlock Grid.Row="2"
                               x:Name="CategoryHintText"
                               Height="42"
                               Text="选中图片后标记；智能仅识别内置分类"
                               Style="{StaticResource SecondaryTextStyle}"
                               TextWrapping="WrapWholeWords"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="2"
                               VerticalAlignment="Top">
                        <ToolTipService.ToolTip>
                            <ToolTip>
                                <TextBlock Text="{x:Bind CategoryHintText.Text, Mode=OneWay}"
                                           MaxWidth="480"
                                           TextWrapping="WrapWholeWords"/>
                            </ToolTip>
                        </ToolTipService.ToolTip>
                    </TextBlock>
                    <Button Grid.Row="3"
                            x:Name="AllPhotosCategoryButton"
                            Style="{StaticResource CategoryItemButtonStyle}"
                            Click="AllPhotosCategoryButton_OnClick">
                        <Grid Padding="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="全部照片" FontSize="12"/>
                            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundBrush}" CornerRadius="10" Padding="8,2">
                                <TextBlock x:Name="AllPhotosCountText"
                                           Tag="SelectionCountBadge"
                                           Text="0"
                                           Style="{StaticResource SecondaryTextStyle}"/>
                            </Border>
                        </Grid>
                    </Button>
                    <ScrollViewer Grid.Row="4"
                                  VerticalScrollMode="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollMode="Disabled"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,16,0">
                        <StackPanel x:Name="CategoryListPanel" Spacing="5"/>
                    </ScrollViewer>
                </Grid>

            </Grid>
        </Border>

        <Grid x:Name="MainContent" Grid.Row="1" Grid.Column="1" Margin="0,8,6,8" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Spacing="22">
                <StackPanel Spacing="4">
                    <TextBlock Text="媒体" Style="{StaticResource SectionLabelStyle}"/>
                    <Grid ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84"/>
                            <ColumnDefinition Width="84"/>
                        </Grid.ColumnDefinitions>
                        <ToggleButton x:Name="ImageKindButton"
                                      Grid.Column="0"
                                      Height="30"
                                      Tag="Image"
                                      Content="图片"
                                      IsChecked="True"
                                      Style="{StaticResource SelectionToggleButtonStyle}"
                                      Click="MediaKindButton_OnClick"/>
                        <ToggleButton x:Name="VideoKindButton"
                                      Grid.Column="1"
                                      Height="30"
                                      Tag="Video"
                                      Content="视频"
                                      Style="{StaticResource SelectionToggleButtonStyle}"
                                      Click="MediaKindButton_OnClick"/>
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="浏览方式" Style="{StaticResource SectionLabelStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ToggleButton x:Name="FlatBrowseModeButton"
                                      Width="76"
                                      Height="30"
                                      Tag="Flat"
                                      Content="平铺"
                                      Style="{StaticResource SelectionToggleButtonStyle}"
                                      Click="BrowseModeButton_OnClick"/>
                        <ToggleButton x:Name="DirectoryBrowseModeButton"
                                      Width="84"
                                      Height="30"
                                      Tag="DirectoryGrouped"
                                      Content="按目录"
                                      Style="{StaticResource SelectionToggleButtonStyle}"
                                      Click="BrowseModeButton_OnClick"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="DirectoryGroupActions"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Bottom"
                            Visibility="Collapsed">
                    <Button x:Name="CollapseAllGroupsButton"
                            Width="32"
                            Height="30"
                            Padding="0"
                            Style="{StaticResource QuietActionButtonStyle}"
                            ToolTipService.ToolTip="全部折叠"
                            AutomationProperties.Name="全部折叠目录"
                            Click="CollapseAllGroupsButton_OnClick">
                        <FontIcon Glyph="&#xE70E;" FontSize="12"/>
                    </Button>
                    <Button x:Name="ExpandAllGroupsButton"
                            Width="32"
                            Height="30"
                            Padding="0"
                            Style="{StaticResource QuietActionButtonStyle}"
                            ToolTipService.ToolTip="全部展开"
                            AutomationProperties.Name="全部展开目录"
                            Click="ExpandAllGroupsButton_OnClick">
                        <FontIcon Glyph="&#xE70D;" FontSize="12"/>
                    </Button>
                </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom"
                            Spacing="8">
                    <TextBlock Text="缩略图大小" Style="{StaticResource SecondaryTextStyle}" VerticalAlignment="Center"/>
                    <Slider x:Name="ThumbnailSlider"
                            Width="150"
                            Minimum="120"
                            Maximum="260"
                            StepFrequency="10"
                            PointerWheelChanged="ThumbnailSlider_OnPointerWheelChanged"
                            ValueChanged="ThumbnailSlider_OnValueChanged"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Style="{StaticResource InsetPanelStyle}">
                <Grid>
                    <GridView x:Name="ImageGridView"
                              SelectionMode="Extended"
                              IsItemClickEnabled="True"
                              ItemClick="ImageGridView_OnItemClick"
                              SelectionChanged="ImageGridView_OnSelectionChanged"
                              DoubleTapped="ImageGridView_OnDoubleTapped"
                              RightTapped="ImageGridView_OnRightTapped"
                              SizeChanged="ImageGridView_OnSizeChanged"
                              Background="Transparent"
                              Padding="8,8,10,8">
                        <GridView.GroupStyle>
                            <GroupStyle HidesIfEmpty="False">
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Button Tag="{Binding}"
                                                Height="30"
                                                Margin="4,5,24,1"
                                                Padding="4,0"
                                                MinWidth="320"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                Loaded="MediaGroupHeader_OnLoaded"
                                                Unloaded="MediaGroupHeader_OnUnloaded"
                                                Click="MediaGroupHeader_OnClick">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"/>
                                                <Border Grid.Column="1"
                                                        MinWidth="38"
                                                        Margin="10,0,8,0"
                                                        Padding="7,2"
                                                        CornerRadius="10"
                                                        Background="{ThemeResource AccentSoftBrush}"
                                                        HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding CountText}"
                                                               FontSize="11"
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                                <FontIcon Grid.Column="2"
                                                          Glyph="{Binding ChevronGlyph}"
                                                          Width="18"
                                                          FontSize="11"
                                                          Foreground="{ThemeResource TextSecondaryBrush}"
                                                          VerticalAlignment="Center"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </GridView.GroupStyle>
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Border Width="{Binding ThumbnailWidth}"
                                        Height="{Binding ThumbnailHeight}"
                                        Margin="4"
                                        ToolTipService.ToolTip="{Binding FullPath}"
                                        Background="{ThemeResource CardBackgroundBrush}"
                                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Image Grid.Row="0"
                                               Source="{Binding Thumbnail}"
                                               Stretch="UniformToFill"/>
                                        <FontIcon Grid.Row="0"
                                                  Glyph="&#xE714;"
                                                  FontSize="30"
                                                  Foreground="{ThemeResource TextTertiaryBrush}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Visibility="{Binding VideoFallbackVisibility}"/>
                                        <Border Grid.Row="0"
                                                Width="34"
                                                Height="34"
                                                CornerRadius="17"
                                                Background="#B3000000"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding VideoPlayBadgeVisibility}">
                                            <FontIcon Glyph="&#xE768;" FontSize="16" Foreground="White"/>
                                        </Border>
                                        <Border Grid.Row="1" Background="#A6000000" Padding="7,4">
                                            <TextBlock Text="{Binding FileName}" Foreground="White" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                        <TextBlock Text="{Binding FavoriteMark}"
                                                   Grid.Row="0"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Top"
                                                   Margin="0,5,7,0"
                                                   Foreground="{ThemeResource WarningBrush}"
                                                   FontSize="16"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                    <StackPanel x:Name="EmptyText" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xEB9F;" FontSize="28" Foreground="{ThemeResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="EmptyMessageText"
                                   Text="选择一个图片文件夹开始浏览"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="DetailPane" Grid.Row="1" Grid.Column="2" Margin="0,8,8,8" Padding="14" Style="{StaticResource PanelBorderStyle}">
            <ScrollViewer x:Name="DetailScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          SizeChanged="DetailScrollViewer_OnSizeChanged">
                <Grid x:Name="DetailContentGrid">
                    <StackPanel Spacing="8">
                    <Border x:Name="SelectedImagePreviewFrame"
                            Height="154"
                            CornerRadius="6"
                            Background="{ThemeResource CardBackgroundBrush}"
                            BorderBrush="{ThemeResource BorderSubtleBrush}"
                            BorderThickness="1">
                        <Grid x:Name="PreviewVideoSurface"
                              PointerPressed="PreviewVideoSurface_OnPointerPressed">
                            <Image x:Name="PreviewImage" Stretch="Uniform" Margin="6"/>
                            <MediaPlayerElement x:Name="PreviewVideoPlayer"
                                                Visibility="Collapsed"
                                                AreTransportControlsEnabled="False"
                                                AutoPlay="False"
                                                Stretch="Uniform"/>
                            <Border x:Name="PreviewVideoControls"
                                    Visibility="Collapsed"
                                    VerticalAlignment="Bottom"
                                    Margin="6"
                                    Padding="4"
                                    CornerRadius="4"
                                    Background="#D9181C23">
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="PreviewPlayPauseButton"
                                            Width="30"
                                            Height="30"
                                            MinWidth="30"
                                            MinHeight="30"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="PreviewPlayPauseButton_OnClick"
                                            AutomationProperties.Name="播放"
                                            ToolTipService.ToolTip="播放或暂停">
                                        <FontIcon x:Name="PreviewPlayPauseIcon"
                                                  Glyph="&#xE768;"
                                                  FontSize="14"
                                                  Foreground="White"/>
                                    </Button>
                                    <Slider x:Name="PreviewProgressSlider"
                                            Grid.Column="1"
                                            Height="30"
                                            Minimum="0"
                                            Maximum="1"
                                            ValueChanged="PreviewProgressSlider_OnValueChanged"
                                            AutomationProperties.Name="播放进度"/>
                                    <TextBlock x:Name="PreviewVideoTimeText"
                                               Grid.Column="2"
                                               MinWidth="62"
                                               Text="0:00 / 0:00"
                                               FontSize="10"
                                               Foreground="White"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="PreviewMuteButton"
                                            Grid.Column="3"
                                            Width="30"
                                            Height="30"
                                            MinWidth="30"
                                            MinHeight="30"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="PreviewMuteButton_OnClick"
                                            AutomationProperties.Name="静音"
                                            ToolTipService.ToolTip="静音或恢复声音">
                                        <FontIcon x:Name="PreviewMuteIcon"
                                                  Glyph="&#xE767;"
                                                  FontSize="14"
                                                  Foreground="White"/>
                                    </Button>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="PreviewVideoErrorText"
                                       Visibility="Collapsed"
                                       Text="无法播放此视频，请检查系统编解码器。"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="16"
                                       Style="{StaticResource SecondaryTextStyle}"/>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="DetailFileName"
                               Text="未选择图片"
                               Height="24"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"
                               VerticalAlignment="Center">
                        <ToolTipService.ToolTip>
                            <ToolTip>
                                <TextBlock Text="{x:Bind DetailPath.Text, Mode=OneWay}"
                                           MaxWidth="560"
                                           TextWrapping="WrapWholeWords"/>
                            </ToolTip>
                        </ToolTipService.ToolTip>
                    </TextBlock>

                    <Grid MinHeight="124" RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Text="分辨率" Style="{StaticResource SecondaryTextStyle}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetailResolution" Text="-" Style="{StaticResource SecondaryTextStyle}"/>
                        <TextBlock Grid.Row="1" Text="大小" Style="{StaticResource SecondaryTextStyle}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetailSize" Text="-" Style="{StaticResource SecondaryTextStyle}"/>
                        <TextBlock Grid.Row="2" Text="修改时间" Style="{StaticResource SecondaryTextStyle}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DetailTime" Text="-" Style="{StaticResource SecondaryTextStyle}"/>
                        <TextBlock Grid.Row="3" Text="路径" Style="{StaticResource SecondaryTextStyle}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DetailPath" Text="-" Style="{StaticResource SecondaryTextStyle}" TextWrapping="WrapWholeWords" TextTrimming="CharacterEllipsis" MaxLines="2" VerticalAlignment="Top">
                            <ToolTipService.ToolTip>
                                <ToolTip>
                                    <TextBlock Text="{x:Bind DetailPath.Text, Mode=OneWay}"
                                               MaxWidth="560"
                                               TextWrapping="WrapWholeWords"/>
                                </ToolTip>
                            </ToolTipService.ToolTip>
                        </TextBlock>
                    </Grid>

                    <Border Height="1" Background="{ThemeResource BorderSubtleBrush}" Margin="0,2"/>

                    <Grid MinHeight="32" ColumnSpacing="8" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="标签"
                                   Style="{StaticResource SectionLabelStyle}"
                                   Margin="0"
                                   VerticalAlignment="Center"/>
                        <ItemsControl Grid.Column="1"
                                      x:Name="SelectedCategoriesItems"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2,6,2"
                                            Padding="8,2,3,2"
                                            MinHeight="22"
                                            CornerRadius="11"
                                            Background="{ThemeResource AccentSoftBrush}">
                                        <Grid ColumnSpacing="3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1"
                                                    Tag="{Binding}"
                                                    Width="16"
                                                    Height="16"
                                                    MinWidth="0"
                                                    MinHeight="0"
                                                    Padding="0"
                                                    BorderThickness="0"
                                                    Background="Transparent"
                                                    VerticalAlignment="Top"
                                                    ToolTipService.ToolTip="从所选图片移除此标签"
                                                    Click="SelectedCategoryRemoveButton_OnClick">
                                                <FontIcon Glyph="&#xE711;" FontSize="8"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <TextBlock Text="快速操作" Style="{StaticResource SectionLabelStyle}"/>
                    <Grid ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" x:Name="ViewButton" IsEnabled="False" Style="{StaticResource QuickActionButtonStyle}" Click="ViewButton_OnClick">
                            <StackPanel HorizontalAlignment="Center" Spacing="3">
                                <FontIcon Glyph="&#xE890;" FontSize="14"/>
                                <TextBlock Text="查看" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" x:Name="FavoriteButton" IsEnabled="False" Style="{StaticResource QuickActionButtonStyle}" Click="FavoriteButton_OnClick">
                            <StackPanel HorizontalAlignment="Center" Spacing="3">
                                <FontIcon Glyph="&#xE734;" FontSize="14" Foreground="{ThemeResource WarningBrush}"/>
                                <TextBlock x:Name="FavoriteButtonLabel" Text="收藏" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" x:Name="OpenLocationButton" IsEnabled="False" Style="{StaticResource QuickActionButtonStyle}" Click="OpenLocationButton_OnClick">
                            <StackPanel HorizontalAlignment="Center" Spacing="3">
                                <FontIcon Glyph="&#xE8B7;" FontSize="14"/>
                                <TextBlock Text="位置" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" x:Name="MoreActionButton" IsEnabled="False" Style="{StaticResource QuickActionButtonStyle}" Click="MoreActionButton_OnClick">
                            <StackPanel HorizontalAlignment="Center" Spacing="3">
                                <FontIcon Glyph="&#xE712;" FontSize="14"/>
                                <TextBlock Text="更多" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <Button x:Name="DeleteButton" Visibility="Collapsed" IsEnabled="False" Click="DeleteButton_OnClick"/>

                    <Border Height="1" Background="{ThemeResource BorderSubtleBrush}" Margin="0,2"/>

                    <TextBlock Text="壁纸设置" Style="{StaticResource SectionLabelStyle}"/>
                    <Grid ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ToggleButton Grid.Column="0" x:Name="WallpaperFillButton" IsEnabled="False" Tag="fill" Style="{StaticResource WallpaperFitButtonStyle}" Click="WallpaperFitButton_OnClick">
                            <StackPanel HorizontalAlignment="Center" Spacing="3"><FontIcon Glyph="&#xE8B9;" FontSize="13"/><TextBlock Text="填充" FontSize="12"/></StackPanel>
                        </ToggleButton>
                        <ToggleButton Grid.Column="1" x:Name="WallpaperFitButton" IsEnabled="False" Tag="fit" Style="{StaticResource WallpaperFitButtonStyle}" Click="WallpaperFitButton_OnClick">
                            <StackPanel HorizontalAlignment="Center" Spacing="3"><FontIcon Glyph="&#xE9A6;" FontSize="13"/><TextBlock Text="适中" FontSize="12"/></StackPanel>
                        </ToggleButton>
                        <ToggleButton Grid.Column="2" x:Name="WallpaperCenterButton" IsEnabled="False" Tag="center" Style="{StaticResource WallpaperFitButtonStyle}" Click="WallpaperFitButton_OnClick">
                            <StackPanel HorizontalAlignment="Center" Spacing="3"><FontIcon Glyph="&#xE73D;" FontSize="13"/><TextBlock Text="居中" FontSize="12"/></StackPanel>
                        </ToggleButton>
                        <ToggleButton Grid.Column="3" x:Name="WallpaperTileButton" IsEnabled="False" Tag="tile" Style="{StaticResource WallpaperFitButtonStyle}" Click="WallpaperFitButton_OnClick">
                            <StackPanel HorizontalAlignment="Center" Spacing="3"><FontIcon Glyph="&#xECA5;" FontSize="13"/><TextBlock Text="平铺" FontSize="12"/></StackPanel>
                        </ToggleButton>
                        <ToggleButton Grid.Column="4" x:Name="WallpaperStretchButton" IsEnabled="False" Tag="stretch" Style="{StaticResource WallpaperFitButtonStyle}" Click="WallpaperFitButton_OnClick">
                            <StackPanel HorizontalAlignment="Center" Spacing="3"><FontIcon Glyph="&#xE740;" FontSize="13"/><TextBlock Text="拉伸" FontSize="12"/></StackPanel>
                        </ToggleButton>
                    </Grid>

                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="AddToAlbumButton" IsEnabled="False" Style="{StaticResource DetailBarButtonStyle}" Click="AddToAlbumButton_OnClick">
                            <TextBlock x:Name="AlbumActionButtonLabel" Text="加入相册" FontSize="12"/>
                        </Button>
                        <Button Grid.Column="1" x:Name="WallpaperFavoriteButton" IsEnabled="False" Style="{StaticResource DetailBarButtonStyle}" Click="WallpaperFavoriteButton_OnClick">
                            <TextBlock x:Name="WallpaperFavoriteButtonLabel" Text="壁纸收藏" FontSize="12"/>
                        </Button>
                    </Grid>

                    <ComboBox x:Name="WallpaperDisplayBox" Height="32" HorizontalAlignment="Stretch" SelectedIndex="0" IsEnabled="False">
                        <ComboBoxItem Content="所有显示器"/>
                    </ComboBox>
                    <Button x:Name="WallpaperButton"
                            IsEnabled="False"
                            Height="34"
                            HorizontalAlignment="Stretch"
                            BorderBrush="{ThemeResource ActionButtonBorderBrush}"
                            BorderThickness="1"
                            Style="{StaticResource CompactButtonStyle}"
                            Click="WallpaperButton_OnClick">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                            <FontIcon Glyph="&#xE7F4;" FontSize="13"/>
                            <TextBlock Text="设为壁纸" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="3"
                Background="{ThemeResource ChromeBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                    <TextBlock x:Name="StatusText"
                               Width="200"
                               Text="就绪"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource SecondaryTextStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8" Fill="{ThemeResource SuccessBrush}"/>
                        <Grid Width="318" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="62"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="178"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="58"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CpuStatusText"
                                       Text="CPU --"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource SecondaryTextStyle}"/>
                            <Border Grid.Column="1"
                                    Width="1"
                                    Height="12"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource BorderSubtleBrush}"/>
                            <TextBlock x:Name="MemoryStatusText"
                                       Grid.Column="2"
                                       Text="内存 --/-- GB (--%)"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource SecondaryTextStyle}"/>
                            <Border Grid.Column="3"
                                    Width="1"
                                    Height="12"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource BorderSubtleBrush}"/>
                            <TextBlock x:Name="GpuStatusText"
                                       Grid.Column="4"
                                       Text="GPU --"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource SecondaryTextStyle}"/>
                        </Grid>
                    </StackPanel>
                    <StackPanel Width="126" Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8" Fill="{ThemeResource AccentPrimaryBrush}"/>
                        <TextBlock x:Name="ScanStateText"
                                   Width="108"
                                   Text="等待扫描"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{StaticResource SecondaryTextStyle}"/>
                    </StackPanel>
                    <StackPanel Width="154" Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8" Fill="{ThemeResource SuccessBrush}"/>
                        <TextBlock x:Name="CacheStatusText"
                                   Width="138"
                                   Text="缩略图按需加载"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{StaticResource SecondaryTextStyle}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10">
                    <TextBlock x:Name="ScanProgressText"
                               Text="显示：0 / 0"
                               Style="{StaticResource SecondaryTextStyle}"
                               VerticalAlignment="Center"/>
                    <ProgressBar x:Name="ScanActivityIndicator"
                                 Width="132"
                                 Height="4"
                                 IsIndeterminate="True"
                                 Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ViewerOverlay"
              Grid.RowSpan="3"
              Grid.ColumnSpan="3"
              Visibility="Collapsed"
              IsTabStop="True"
              Background="#E6000000"
              KeyDown="ViewerOverlay_OnKeyDown"
              PointerWheelChanged="ViewerOverlay_OnPointerWheelChanged"
              PointerPressed="ViewerOverlay_OnPointerPressed"
              PointerMoved="ViewerOverlay_OnPointerMoved"
              PointerReleased="ViewerOverlay_OnPointerReleased">
            <Image x:Name="ViewerImage" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <CompositeTransform x:Name="ViewerTransform"/>
                </Image.RenderTransform>
            </Image>
            <MediaPlayerElement x:Name="ViewerVideoPlayer"
                                Visibility="Collapsed"
                                AreTransportControlsEnabled="False"
                                AutoPlay="False"
                                Stretch="Uniform"
                                Margin="24"/>
            <Border x:Name="ViewerVideoControls"
                    Visibility="Collapsed"
                    Width="760"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="24"
                    Padding="8"
                    CornerRadius="6"
                    Background="#D9181C23"
                    PointerPressed="ViewerVideoControls_OnPointerPressed"
                    PointerReleased="ViewerVideoControls_OnPointerReleased">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="ViewerPlayPauseButton"
                            Width="34"
                            Height="34"
                            MinWidth="34"
                            MinHeight="34"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="ViewerPlayPauseButton_OnClick"
                            AutomationProperties.Name="播放"
                            ToolTipService.ToolTip="播放或暂停">
                        <FontIcon x:Name="ViewerPlayPauseIcon"
                                  Glyph="&#xE768;"
                                  FontSize="15"
                                  Foreground="White"/>
                    </Button>
                    <Slider x:Name="ViewerProgressSlider"
                            Grid.Column="1"
                            Height="34"
                            Minimum="0"
                            Maximum="1"
                            ValueChanged="ViewerProgressSlider_OnValueChanged"
                            AutomationProperties.Name="播放进度"/>
                    <TextBlock x:Name="ViewerVideoTimeText"
                               Grid.Column="2"
                               MinWidth="86"
                               Text="0:00 / 0:00"
                               FontSize="11"
                               Foreground="White"
                               TextAlignment="Right"
                               VerticalAlignment="Center"/>
                    <Button x:Name="ViewerMuteButton"
                            Grid.Column="3"
                            Width="34"
                            Height="34"
                            MinWidth="34"
                            MinHeight="34"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="ViewerMuteButton_OnClick"
                            AutomationProperties.Name="静音"
                            ToolTipService.ToolTip="静音或恢复声音">
                        <FontIcon x:Name="ViewerMuteIcon"
                                  Glyph="&#xE767;"
                                  FontSize="15"
                                  Foreground="White"/>
                    </Button>
                </Grid>
            </Border>
            <TextBlock x:Name="ViewerVideoErrorText"
                       Visibility="Collapsed"
                       Text="无法播放此视频，请检查系统编解码器。"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            <Border Background="#99000000" Padding="16,8" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,76" CornerRadius="8">
                <TextBlock x:Name="ViewerCaption" Foreground="White"/>
            </Border>
        </Grid>
    </Grid>
</Window>
